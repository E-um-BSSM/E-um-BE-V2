# Copy to deploy/.env and fill in real values. deploy/.env is git-ignored — never
# put real secrets in this .example file, it IS tracked by git.

# Database (DB_URL host must be the compose service name "mysql", not localhost,
# when running via deploy/docker-compose.yml — the app container reaches the db
# container over the compose network, not the host's localhost)
DB_URL=jdbc:mysql://mysql:3306/eumbe?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=change-me

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-base64-secret
JWT_ACCESS_VALIDITY_SECONDS=3600
JWT_REFRESH_VALIDITY_SECONDS=1209600
JWT_REFRESH_KEEP_SIGNED_IN_VALIDITY_SECONDS=2592000

# SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# CORS — required, no default in application-prod.properties
CORS_ALLOWED_ORIGINS=http://localhost:5174
CORS_ALLOW_CREDENTIALS=false

# Frontend
FRONTEND_BASE_URL=http://localhost:5174

# Verification
EMAIL_CODE_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_MINUTES=30